body {
    margin: 0;
    background: linear-gradient(#ffd6ec, #fff0f8);
    font-family: Arial, sans-serif;
    text-align: center;
}

h1 {
    color: #ff4fa3;
    margin-top: 20px;
}

canvas {
    background: #87CEEB;
    border: 6px solid #ff9acb;
    border-radius: 15px;
    margin-top: 20px;
}
